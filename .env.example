# Proveedor de LLM: "gemini" o "ollama"
LLM_PROVIDER=gemini

# --- Configuración Google Gemini (requerido si LLM_PROVIDER=gemini) ---
GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL_NAME=gemini-2.5-flash-lite
# GEMINI_EMBEDDINGS_MODEL=models/text-embedding-004

# --- Configuración Ollama (requerido si LLM_PROVIDER=ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
# OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text

# Directorio donde ChromaDB almacenará los datos de forma persistente.
# Por defecto es "./data/chroma_db"
# CHROMA_PERSIST_DIRECTORY=./data/my_chroma_db

# Nombre del proyecto para Arize Phoenix.
# Por defecto es "rag-lab"
# PHOENIX_PROJECT_NAME=rag-lab

# Número de documentos a recuperar del vector store por consulta.
# Por defecto es 5
# RETRIEVER_K=5

# Temperatura del LLM (0.0 = determinista, 1.0 = creativo).
# Por defecto es 0.7
# LLM_TEMPERATURE=0.7

# Tamaño de cada chunk al ingestar documentos (en caracteres).
# Por defecto es 1000
# CHUNK_SIZE=1000

# Solapamiento entre chunks consecutivos (en caracteres).
# Por defecto es 200
# CHUNK_OVERLAP=200
